{
  "name": "scribe",
  "version": "1.7.0",
  "description": "SCRIBE — a free, private, local-first voice-dictation utility. Speak freely; get text you'd have been proud to type.",
  "main": "out/main/index.js",
  "author": "LivesCreate",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "package": "electron-vite build && electron-builder --win nsis",
    "postinstall": "cd node_modules/better-sqlite3 && npx prebuild-install --runtime=electron --target=38.8.6 --arch=x64"
  },
  "dependencies": {
    "@fontsource/newsreader": "^5.2.10",
    "better-sqlite3": "^12.11.1",
    "ffmpeg-static": "^5.3.0",
    "koffi": "^3.1.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "38.8.6",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
